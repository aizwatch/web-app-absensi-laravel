# =============================================
# APP
# =============================================
APP_NAME="Absensi LT"
APP_ENV=production
APP_KEY=                            # jalankan: php artisan key:generate
APP_DEBUG=false
APP_URL=https://absensi.domain.anda

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# =============================================
# DATABASE MYSQL (wajib diisi)
# =============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=finger_db
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# FINGERSPOT (wajib diisi)
# Cloud ID: cek di mesin atau dashboard Fingerspot
# Pisah koma jika lebih dari 1 mesin
# API Token: dari developer.fingerspot.io
# =============================================
FINGERSPOT_CLOUD_IDS=CLOUD_ID_MESIN1,CLOUD_ID_MESIN2
FINGERSPOT_API_TOKEN=ISI_API_TOKEN_DISINI

# =============================================
# LOG
# =============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# =============================================
# SESSION & CACHE
# Pakai "file" agar tidak perlu tabel DB tambahan
# =============================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=file
QUEUE_CONNECTION=sync

# =============================================
# TIDAK DIPAKAI — biarkan default
# =============================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
VITE_APP_NAME="${APP_NAME}"
